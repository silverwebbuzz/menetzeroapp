# Application
APP_NAME=MeNetZero
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Default mail transport (log | smtp)
MAIL_MAILER=log

# Shared SMTP fallback (used when per-mailbox *_HOST is not set)
MAIL_SCHEME=
# Leave empty for STARTTLS on port 587, or use smtps for SSL on port 465.
# Legacy MAIL_ENCRYPTION=tls|ssl is also mapped automatically.
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_EHLO_DOMAIN=menetzero.com

# Global from (legacy — prefer per-mailbox below)
MAIL_FROM_ADDRESS=noreply@menetzero.com
MAIL_FROM_NAME="${APP_NAME}"

# MeNetZero mailboxes
MAIL_HELLO_ADDRESS=hello@menetzero.com
MAIL_HELLO_NAME="${APP_NAME}"
MAIL_HELLO_HOST=
MAIL_HELLO_PORT=
MAIL_HELLO_USERNAME=
MAIL_HELLO_PASSWORD=

MAIL_HELP_ADDRESS=help@menetzero.com
MAIL_HELP_NAME="${APP_NAME} Support"
MAIL_HELP_HOST=
MAIL_HELP_PORT=
MAIL_HELP_USERNAME=
MAIL_HELP_PASSWORD=

MAIL_NOREPLY_ADDRESS=noreply@menetzero.com
MAIL_NOREPLY_NAME="${APP_NAME}"
MAIL_NOREPLY_HOST=
MAIL_NOREPLY_PORT=
MAIL_NOREPLY_USERNAME=
MAIL_NOREPLY_PASSWORD=

# Internal system alerts (defaults to help@)
MAIL_ALERT_TO=help@menetzero.com
# Optional: copy all outgoing mail to this address (admin can override in Email Tester)
MAIL_GLOBAL_BCC=

# Optional: send email verification on company registration (requires verification routes)
EMAIL_VERIFICATION_ON_REGISTER=false
